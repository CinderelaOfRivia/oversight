{
  "functions": {
    "src/app/api/**/route.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "crons": [
    {
      "path": "/api/cron/health",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/security",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/notifications",
      "schedule": "0 18 * * *"
    }
  ]
}